                em.merge(clientes[i]);
            }
            em.getTransaction().commit();
            System.out.println("Clientes exportados a la base de datos correctamente.");
        } catch (Exception e) {
            if (em.getTransaction().isActive()) {
                em.getTransaction().rollback();
            }
            System.err.println("Error al exportar clientes: " + e.getMessage());
        } finally {
            em.close();
            emf.close();
        }
    }

    /**
     * Importa los clientes desde ObjectDB al sistema.
     *
     * @param nombreBBDD Ruta del archivo .odb
     */
    public void importClientesFromBBDDOO(String nombreBBDD) {
        EntityManagerFactory emf = javax.persistence.Persistence.createEntityManagerFactory(nombreBBDD);
        EntityManager em = emf.createEntityManager();

        try {
            javax.persistence.TypedQuery<Cliente> query = em.createQuery("SELECT c FROM Cliente c", Cliente.class);
            java.util.List<Cliente> resultados = query.getResultList();

            for (Cliente c : resultados) {
                try {
                    this.altaCliente(c);
                } catch (Exception e) {
                    System.out.println("Cliente omitido (DNI duplicado o inválido): " + c.getDni());
                }
            }
            System.out.println("Importación de clientes desde la base de datos finalizada.");
        } catch (Exception e) {
            System.err.println("Error al importar clientes: " + e.getMessage());
        } finally {
            em.close();
            emf.close();
        }
    }
