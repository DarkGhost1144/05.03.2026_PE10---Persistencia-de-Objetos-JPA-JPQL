        try {
            // Lo hacemos para escribir el fichero 
            FileWriter fw = new FileWriter(ruta);
            BufferedWriter bw = new BufferedWriter(fw);

            for (Cliente c : clientes) {
                // Guardamos los datos separados por ';'
                bw.write(c.getNombre() + ";" + c.getDni() + ";" + c.getEmail() + ";" + c.getLugarResidencia());
                bw.newLine(); // Salto de linea
            }

            System.out.println("Clientes exportados a texto correctamente en: " + ruta);

            bw.close();
            fw.close();

        } catch (IOException e) {
            System.err.println("Error al exportar clientes a texto: " + e.getMessage());
        }
    }

