    /**
     * Exporta todos los alojamientos almacenados en el array actual a una
     * BBDDOO ObjectDB.
     *
     * @param nombreBBDD Ruta del archivo (ej: "datos/javito.odb")
     */
    public void exportAlojamientosToBBDDOO(String nombreBBDD) {
        EntityManagerFactory emf = javax.persistence.Persistence.createEntityManagerFactory(nombreBBDD);
        EntityManager em = emf.createEntityManager();

        try {
            em.getTransaction().begin();
            // Recorremos el array hasta el contador actual
            for (int i = 0; i < numAlojamientos; i++) {
                // merge actualiza si existe o inserta si es nuevo basado en el @Id (nombre)
                em.merge(alojamientos[i]);
            }
            em.getTransaction().commit();
            System.out.println("Alojamientos exportados a la base de datos correctamente.");
        } catch (Exception e) {
            if (em.getTransaction().isActive()) {
                em.getTransaction().rollback();
            }
            System.err.println("Error al exportar alojamientos: " + e.getMessage());
        } finally {
            em.close();
            emf.close();
        }
    }

    /**
     * Importa los alojamientos desde ObjectDB y los añade al sistema.
     *
     * @param nombreBBDD Ruta del archivo .odb
     */
    public void importAlojamientosFromBBDDOO(String nombreBBDD) {
        EntityManagerFactory emf = javax.persistence.Persistence.createEntityManagerFactory(nombreBBDD);
        EntityManager em = emf.createEntityManager();

        try {
            TypedQuery<Alojamiento> query = em.createQuery("SELECT a FROM Alojamiento a", Alojamiento.class);
            List<Alojamiento> resultados = query.getResultList();

            for (Alojamiento a : resultados) {
                try {
                    this.altaAlojamiento(a);
                } catch (AlojamientoExistenteException e) {
                    System.out.println("Alojamiento ya presente en memoria: " + a.getNombre());
                }
            }
            System.out.println("Importacion desde la base de datos finalizada.");
        } catch (Exception e) {
            System.err.println("Error al importar alojamientos: " + e.getMessage());
        } finally {
            em.close();
            emf.close();
        }
    }

