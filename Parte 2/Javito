    /**
     * Lee un fichero de texto y anade los clientes al sistema.
     */
    public void addClientesFromFicheroTexto(String ruta) throws DniNoValidoException, EmailNoValidoException {
        try {
            // Lo hacemos para leer el fichero
            FileReader fr = new FileReader(ruta);
            BufferedReader br = new BufferedReader(fr);

            String linea;

            while ((linea = br.readLine()) != null) {
                String[] datos = linea.split(";");
                if (datos.length >= 4) {
                    Cliente c = new Cliente(datos[0], datos[1], datos[2], datos[3]);
                    try {
                        this.altaCliente(c);
                    } catch (Exception e) {
                        System.out.println("No se pudo importar el cliente " + datos[1] + ": " + e.getMessage());
                    }
                }
            }

            System.out.println("Clientes importados desde texto correctamente.");

            br.close();
            fr.close();

        } catch (IOException e) {
            System.err.println("Error al leer el fichero de clientes: " + e.getMessage());
        }
    }

    /**
     * Lee un fichero de texto y anade los alojamientos al sistema.
     */
    public void addAlojamientosFromFicheroTexto(String ruta) {
        try {
            FileReader fr = new FileReader(ruta);
            BufferedReader br = new BufferedReader(fr);

            String linea;
            while ((linea = br.readLine()) != null) {
                String[] datos = linea.split(";");
                if (datos.length >= 5) {
                    try {
                        String nombre = datos[0];
                        int capacidad = Integer.parseInt(datos[1]);
                        double tarifa = Double.parseDouble(datos[2]);
                        boolean chimenea = Boolean.parseBoolean(datos[3]);
                        boolean jacuzzi = Boolean.parseBoolean(datos[4]);

                        Alojamiento a = new Alojamiento(nombre, capacidad, tarifa, chimenea, jacuzzi);
                        this.altaAlojamiento(a);
                    } catch (AlojamientoExistenteException | NumberFormatException e) {
                        System.out.println("No se pudo importar el alojamiento " + datos[0] + ": " + e.getMessage());
                    }
                }
            }

            System.out.println("Alojamientos importados desde texto correctamente.");

            br.close();
            fr.close();

        } catch (IOException e) {
            System.err.println("Error al leer el fichero de alojamientos: " + e.getMessage());
        }
    }

